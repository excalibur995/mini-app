{
  "name": "nextgen",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=20"
  },
  "engineStrict": true,
  "scripts": {
    "start": "mprocs -c mprocs/host.yaml",
    "ios": "pnpm --filter host ios",
    "android": "pnpm --filter host android",
    "dashboard:start": "pnpm --filter dashboard start:standalone",
    "dashboard:ios": "pnpm --filter dashboard ios",
    "dashboard:android": "pnpm --filter dashboard android",
    "clean": "rm -rf node_modules pnpm-lock.yaml package-lock.json yarn.lock && pnpm --recursive exec rm -rf vendor android/build android/.gradle ios/build ios/Pods ios/Podfile.lock node_modules pnpm-lock.yaml package-lock.json yarn.lock Gemfile.lock",
    "pods": "pnpm -r pods",
    "pods:update": "pnpm -r pods:update",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "align-deps": "pnpm -r align-deps",
    "check-deps": "pnpm -r check-deps"
  },
  "dependencies": {
    "mprocs": "^0.7.3"
  },
  "pnpm": {
    "packageExtensions": {
      "@module-federation/data-prefetch": {
        "peerDependenciesMeta": {
          "react-dom": {
            "optional": true
          }
        }
      }
    },
    "allowedDeprecatedVersions": {
      "eslint": "8"
    }
  }
}
