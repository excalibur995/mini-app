{
  "name": "transfer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --port=8102",
    "ios": "react-native run-ios --port=8102",
    "lint": "eslint .",
    "start": "react-native start --reset-cache --port=8102",
    "start:standalone": "STANDALONE=1 react-native start --port=8102",
    "bundle:ios": "react-native bundle --platform ios --entry-file index.js",
    "bundle:android": "react-native bundle --platform android --entry-file index.js",
    "test": "jest",
    "postinstall": "set -e; cd ios && bundle install && RCT_NEW_ARCH_ENABLED=1 bundle exec pod install && cd ..",
    "pods": "cd ios && RCT_NEW_ARCH_ENABLED=1 bundle exec pod install && cd ..",
    "pods:update": "cd ios && bundle update && RCT_NEW_ARCH_ENABLED=1 bundle exec pod update && cd .."
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@react-native/new-app-screen": "0.81.4",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.28",
    "@swc/helpers": "^0.5.17",
    "mobile-sdk": "file:../../packages/mobile-sdk",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-pager-view": "^6.9.1",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.16.0",
    "react-native-worklets": "^0.7.1",
    "ui-kit": "file:../../packages/ui-kit"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@callstack/repack": "^5.2.1",
    "@callstack/repack-plugin-reanimated": "^5.2.1",
    "@module-federation/enhanced": "^0.8.4",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.4",
    "@react-native/codegen": "0.81.4",
    "@react-native/eslint-config": "0.81.4",
    "@react-native/gradle-plugin": "0.81.4",
    "@react-native/metro-config": "0.81.4",
    "@react-native/typescript-config": "0.81.4",
    "@rspack/cli": "^1.6.7",
    "@rspack/core": "^1.5.8",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
